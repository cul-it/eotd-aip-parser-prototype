{
  "fields": [
    {
      "key": "doi",
      "label": "DOI",
      "type": "string",
      "sources": {
        "MODS": {
          "strategy": "modsIdentifier",
          "mods": { "identifierType": "doi" },
          "xpath": "//mods:identifier[@type='doi']",
          "xmlSearch": { "tag": "mods:identifier", "context": "doi" }
        },
        "DIM": {
          "strategy": "dim",
          "dim": { "mdschema": "dc", "element": "identifier", "qualifier": "doi" },
          "xpath": "//dim:field[@mdschema='dc'][@element='identifier'][@qualifier='doi']",
          "xmlSearch": { "tag": "dim:field", "context": "doi" }
        }
      }
    },
    {
      "key": "handleUrl",
      "label": "Handle URL",
      "type": "string",
      "sources": {
        "MODS": {
          "strategy": "modsIdentifier",
          "mods": { "identifierType": "uri" },
          "xpath": "//mods:identifier[@type='uri']",
          "xmlSearch": { "tag": "mods:identifier", "context": "uri" }
        },
        "DIM": {
          "strategy": "dim",
          "dim": { "mdschema": "dc", "element": "identifier", "qualifier": "uri" },
          "xpath": "//dim:field[@mdschema='dc'][@element='identifier'][@qualifier='uri']",
          "xmlSearch": { "tag": "dim:field", "context": "identifier\" qualifier=\"uri" }
        }
      }
    },
    {
      "key": "instanceHrid",
      "label": "Instance HRID",
      "type": "string",
      "sources": {
        "MODS": {
          "strategy": "modsIdentifier",
          "mods": { "identifierType": "local", "prefix": "bibid:" },
          "xpath": "//mods:identifier[@type='local'][starts-with(.,'bibid:')]",
          "xmlSearch": { "tag": "mods:identifier", "context": "bibid" }
        }
      }
    },
    {
      "key": "title",
      "label": "Title",
      "type": "string",
      "sources": {
        "MODS": {
          "strategy": "modsPath",
          "mods": { "path": ["titleInfo", "title"] },
          "xpath": "//mods:titleInfo/mods:title",
          "xmlSearch": { "tag": "mods:titleInfo" }
        },
        "DIM": {
          "strategy": "dim",
          "dim": { "mdschema": "dc", "element": "title" },
          "xpath": "//dim:field[@mdschema='dc'][@element='title']",
          "xmlSearch": { "tag": "dim:field", "context": "element=\"title\"" }
        }
      }
    },
    {
      "key": "abstract",
      "label": "Abstract",
      "type": "string",
      "sources": {
        "MODS": {
          "strategy": "modsPath",
          "mods": { "path": ["abstract"] },
          "xpath": "//mods:abstract",
          "xmlSearch": { "tag": "mods:abstract" }
        },
        "DIM": {
          "strategy": "dim",
          "dim": { "mdschema": "dc", "element": "description", "qualifier": "abstract" },
          "xpath": "//dim:field[@mdschema='dc'][@element='description'][@qualifier='abstract']",
          "xmlSearch": { "tag": "dim:field", "context": "qualifier=\"abstract\"" }
        }
      }
    },
    {
      "key": "author",
      "label": "Author",
      "type": "string",
      "sources": {
        "MODS": {
          "strategy": "modsName",
          "mods": { "role": "author" },
          "xpath": "//mods:name[mods:role/mods:roleTerm='author']/mods:namePart",
          "xmlSearch": { "tag": "mods:name" }
        },
        "DIM": {
          "strategy": "dim",
          "dim": { "mdschema": "dc", "element": "contributor", "qualifier": "author" },
          "xpath": "//dim:field[@mdschema='dc'][@element='contributor'][@qualifier='author']",
          "xmlSearch": { "tag": "dim:field", "context": "contributor\" qualifier=\"author" }
        }
      }
    },
    {
      "key": "committeeMembers",
      "label": "Committee Members",
      "type": "array",
      "sources": {
        "DIM": {
          "strategy": "dimMulti",
          "dim": [
            { "mdschema": "dc", "element": "contributor", "qualifier": "chair", "role": "chair" },
            { "mdschema": "dc", "element": "contributor", "qualifier": "committeeMember", "role": "member" }
          ],
          "xpath": "//dim:field[@element='contributor'][@qualifier='chair' or @qualifier='committeeMember']",
          "xmlSearch": { "tag": "dim:field", "contexts": ["chair", "committeeMember"] }
        }
      },
      "display": {
        "nested": {
          "headers": ["Name", "Role"],
          "roleColumn": true
        }
      }
    },
    {
      "key": "community",
      "label": "Community",
      "type": "string",
      "hardcoded": "Not currently exposed in AIP",
      "sources": {}
    },
    {
      "key": "collection",
      "label": "Collection",
      "type": "string",
      "sources": {
        "DIM": {
          "strategy": "dim",
          "dim": { "mdschema": "cris", "element": "virtual", "qualifier": "collection", "includeAuthority": true },
          "xpath": "//dim:field[@mdschema='cris'][@element='virtual'][@qualifier='collection']",
          "xmlSearch": { "tag": "dim:field", "context": "cris" }
        }
      }
    },
    {
      "key": "keywords",
      "label": "Keywords",
      "type": "array",
      "sources": {
        "MODS": {
          "strategy": "modsSubjects",
          "xpath": "//mods:subject/mods:topic",
          "xmlSearch": { "tag": "mods:subject", "all": true }
        },
        "DIM": {
          "strategy": "dimMulti",
          "dim": [
            { "mdschema": "dc", "element": "subject" }
          ],
          "xpath": "//dim:field[@mdschema='dc'][@element='subject']",
          "xmlSearch": { "tag": "dim:field", "contexts": ["element=\"subject\""] }
        }
      },
      "display": {
        "nested": {
          "headers": ["Keyword"]
        }
      }
    },
    {
      "key": "datePublished",
      "label": "Date Published",
      "type": "string",
      "sources": {
        "MODS": {
          "strategy": "modsPath",
          "mods": { "path": ["originInfo", "dateIssued"] },
          "xpath": "//mods:originInfo/mods:dateIssued",
          "xmlSearch": { "tag": "mods:originInfo" }
        },
        "DIM": {
          "strategy": "dim",
          "dim": { "mdschema": "dc", "element": "date", "qualifier": "issued" },
          "xpath": "//dim:field[@mdschema='dc'][@element='date'][@qualifier='issued']",
          "xmlSearch": { "tag": "dim:field", "context": "date\" qualifier=\"issued" }
        }
      }
    },
    {
      "key": "dateAddedToEcommons",
      "label": "Date Added to eCommons",
      "type": "string",
      "sources": {
        "MODS": {
          "strategy": "modsExtension",
          "mods": { "extensionField": "dateAccessioned" },
          "xpath": "//mods:extension/mods:dateAccessioned",
          "xmlSearch": { "tag": "mods:dateAccessioned" }
        },
        "DIM": {
          "strategy": "dim",
          "dim": { "mdschema": "dc", "element": "date", "qualifier": "accessioned" },
          "xpath": "//dim:field[@mdschema='dc'][@element='date'][@qualifier='accessioned']",
          "xmlSearch": { "tag": "dim:field", "context": "date\" qualifier=\"accessioned" }
        }
      }
    },
    {
      "key": "bitstreams",
      "label": "Content Files / Bitstreams",
      "type": "bitstreams",
      "sources": {
        "METS": {
          "strategy": "custom",
          "customExtractor": "bitstreams",
          "config": {
            "useTypes": ["ORIGINAL", "LICENSE", "CC-LICENSE"]
          },
          "xpath": "//fileSec/fileGrp[@USE='ORIGINAL' or @USE='LICENSE' or @USE='CC-LICENSE']/file",
          "xmlSearch": { "tag": "fileGrp", "contexts": ["ORIGINAL", "LICENSE", "CC-LICENSE"] }
        }
      },
      "display": {
        "nested": {
          "headers": ["Use", "Filename", "MIME Type", "Size", "Checksum"]
        }
      }
    },
    {
      "key": "license",
      "label": "License",
      "type": "string",
      "sources": {
        "MODS": {
          "strategy": "modsAccessCondition",
          "mods": { "conditionType": "useAndReproduction" },
          "xpath": "//mods:accessCondition[@type='useAndReproduction']",
          "xmlSearch": { "tag": "mods:accessCondition", "all": true }
        },
        "DIM": {
          "strategy": "dim",
          "dim": { "mdschema": "dc", "element": "rights" },
          "xpath": "//dim:field[@mdschema='dc'][@element='rights']",
          "xmlSearch": { "tag": "dim:field", "context": "rights" }
        }
      }
    },
    {
      "key": "embargo",
      "label": "Embargo",
      "type": "string",
      "sources": {
        "DIM": {
          "strategy": "custom",
          "customExtractor": "embargo",
          "config": {
            "permanentThresholdYears": 100
          },
          "xpath": "//dim:field[@element='description'][@qualifier='embargo']",
          "xmlSearch": { "tag": "dim:field", "context": "embargo" }
        }
      }
    },
    {
      "key": "redaction",
      "label": "Redaction",
      "type": "string",
      "sources": {
        "DIM": {
          "strategy": "custom",
          "customExtractor": "redaction",
          "config": {
            "provenanceSources": [
              { "mdschema": "dc", "element": "description", "qualifier": "provenance" },
              { "mdschema": "dc", "element": "provenance" }
            ],
            "keywords": ["redact", "removed"],
            "bitstreamKeywords": ["redact"],
            "replacesField": { "mdschema": "dc", "element": "relation", "qualifier": "replaces" }
          },
          "xpath": "//dim:field[@element='description'][@qualifier='provenance'][contains(.,'redact')] | //dim:field[@element='relation'][@qualifier='replaces']",
          "xmlSearch": { "tag": "dim:field", "context": "redact" }
        }
      }
    }
  ]
}
