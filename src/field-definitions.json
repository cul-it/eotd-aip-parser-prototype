{
  "fields": [
    {
      "key": "doi",
      "label": "DOI",
      "type": "string",
      "strategy": "dim",
      "dim": { "mdschema": "dc", "element": "identifier", "qualifier": "doi" },
      "xpath": "//dim:field[@mdschema='dc'][@element='identifier'][@qualifier='doi']",
      "xmlSearch": { "tag": "dim:field", "context": "doi" }
    },
    {
      "key": "handleUrl",
      "label": "Handle URL",
      "type": "string",
      "strategy": "modsIdentifier",
      "mods": { "identifierType": "uri" },
      "xpath": "//mods:identifier[@type='uri']",
      "xmlSearch": { "tag": "mods:identifier", "context": "uri" }
    },
    {
      "key": "instanceHrid",
      "label": "Instance HRID",
      "type": "string",
      "strategy": "modsIdentifier",
      "mods": { "identifierType": "local", "prefix": "bibid:" },
      "xpath": "//mods:identifier[@type='local'][starts-with(.,'bibid:')]",
      "xmlSearch": { "tag": "mods:identifier", "context": "bibid" }
    },
    {
      "key": "title",
      "label": "Title",
      "type": "string",
      "strategy": "modsPath",
      "mods": { "path": ["titleInfo", "title"] },
      "xpath": "//mods:titleInfo/mods:title",
      "xmlSearch": { "tag": "mods:titleInfo" }
    },
    {
      "key": "abstract",
      "label": "Abstract",
      "type": "string",
      "strategy": "modsPath",
      "mods": { "path": ["abstract"] },
      "xpath": "//mods:abstract",
      "xmlSearch": { "tag": "mods:abstract" }
    },
    {
      "key": "author",
      "label": "Author",
      "type": "string",
      "strategy": "modsName",
      "mods": { "role": "author" },
      "xpath": "//mods:name[mods:role/mods:roleTerm='author']/mods:namePart",
      "xmlSearch": { "tag": "mods:name" }
    },
    {
      "key": "committeeMembers",
      "label": "Committee Members",
      "type": "array",
      "strategy": "dimMulti",
      "dim": [
        { "mdschema": "dc", "element": "contributor", "qualifier": "chair", "role": "chair" },
        { "mdschema": "dc", "element": "contributor", "qualifier": "committeeMember", "role": "member" }
      ],
      "xpath": "//dim:field[@element='contributor'][@qualifier='chair' or @qualifier='committeeMember']",
      "xmlSearch": { "tag": "dim:field", "contexts": ["chair", "committeeMember"] },
      "display": {
        "nested": {
          "headers": ["Name", "Role"],
          "roleColumn": true
        }
      }
    },
    {
      "key": "community",
      "label": "Community",
      "type": "string",
      "strategy": "custom",
      "customExtractor": "community",
      "xpath": "//structMap[@LABEL='Parent']//mptr/@xlink:href",
      "xmlSearch": { "tag": "mptr", "context": "HANDLE" }
    },
    {
      "key": "collection",
      "label": "Collection",
      "type": "string",
      "strategy": "dim",
      "dim": { "mdschema": "cris", "element": "virtual", "qualifier": "collection", "includeAuthority": true },
      "xpath": "//dim:field[@mdschema='cris'][@element='virtual'][@qualifier='collection']",
      "xmlSearch": { "tag": "dim:field", "context": "cris" }
    },
    {
      "key": "keywords",
      "label": "Keywords",
      "type": "array",
      "strategy": "modsSubjects",
      "xpath": "//mods:subject/mods:topic",
      "xmlSearch": { "tag": "mods:subject", "all": true },
      "display": {
        "nested": {
          "headers": ["Keyword"]
        }
      }
    },
    {
      "key": "datePublished",
      "label": "Date Published",
      "type": "string",
      "strategy": "modsPath",
      "mods": { "path": ["originInfo", "dateIssued"] },
      "xpath": "//mods:originInfo/mods:dateIssued",
      "xmlSearch": { "tag": "mods:originInfo" }
    },
    {
      "key": "dateAddedToEcommons",
      "label": "Date Added to eCommons",
      "type": "string",
      "strategy": "modsExtension",
      "mods": { "extensionField": "dateAccessioned" },
      "xpath": "//mods:extension/mods:dateAccessioned",
      "xmlSearch": { "tag": "mods:dateAccessioned" }
    },
    {
      "key": "bitstreams",
      "label": "Content Files / Bitstreams",
      "type": "bitstreams",
      "strategy": "custom",
      "customExtractor": "bitstreams",
      "config": {
        "useTypes": ["ORIGINAL", "LICENSE", "CC-LICENSE"]
      },
      "xpath": "//fileSec/fileGrp[@USE='ORIGINAL' or @USE='LICENSE' or @USE='CC-LICENSE']/file",
      "xmlSearch": { "tag": "fileGrp", "contexts": ["ORIGINAL", "LICENSE", "CC-LICENSE"] },
      "display": {
        "nested": {
          "headers": ["Use", "Filename", "MIME Type", "Size", "Checksum"]
        }
      }
    },
    {
      "key": "license",
      "label": "License",
      "type": "string",
      "strategy": "modsAccessCondition",
      "mods": { "conditionType": "useAndReproduction" },
      "fallback": { "strategy": "dim", "dim": { "mdschema": "dc", "element": "rights" } },
      "xpath": "//mods:accessCondition[@type='useAndReproduction']",
      "xmlSearch": { "tag": "mods:accessCondition", "all": true }
    },
    {
      "key": "embargo",
      "label": "Embargo",
      "type": "string",
      "strategy": "custom",
      "customExtractor": "embargo",
      "config": {
        "permanentThresholdYears": 100
      },
      "xpath": "//dim:field[@element='description'][@qualifier='embargo']",
      "xmlSearch": { "tag": "dim:field", "context": "embargo" }
    },
    {
      "key": "redaction",
      "label": "Redaction",
      "type": "string",
      "strategy": "custom",
      "customExtractor": "redaction",
      "config": {
        "provenanceSources": [
          { "mdschema": "dc", "element": "description", "qualifier": "provenance" },
          { "mdschema": "dc", "element": "provenance" }
        ],
        "keywords": ["redact", "removed"],
        "bitstreamKeywords": ["redact"],
        "replacesField": { "mdschema": "dc", "element": "relation", "qualifier": "replaces" }
      },
      "xpath": "//dim:field[@element='description'][@qualifier='provenance'][contains(.,'redact')] | //dim:field[@element='relation'][@qualifier='replaces']",
      "xmlSearch": { "tag": "dim:field", "context": "redact" }
    }
  ]
}
